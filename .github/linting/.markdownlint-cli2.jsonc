// .github/linting/.markdownlint-cli2.jsonc
{
  "config": {
    "default": true,
    "MD013": { "line_length": 120 },
    "MD033": false,
    "MD041": false
  },
  "customRules": [
    "./.github/linting/rules/*.js"
  ],
  "globs": ["**/*.md"],
  "ignores": [
    "node_modules",
    ".git",
    ".github/ISSUE_TEMPLATE",
    ".github/PULL_REQUEST_TEMPLATE.md"
  ]
}