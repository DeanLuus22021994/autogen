{
  "config": {
    "default": true,
    "MD013": false,
    "MD024": { "siblings_only": true },
    "MD033": { "allowed_elements": ["br", "details", "summary", "div", "img"] },
    "MD041": false
  },
  "ignores": ["**/node_modules/**", "**/.git/**"],
  "customRules": [
    "./rules/**/*.js"
  ],
  "noProgress": true,
  "outputFormatters": [
    ["markdownlint-cli2-formatter-default", {"showRules": true}]
  ]
}