{
	"servers": {
		"sequential-thinking": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-sequential-thinking"
			]
		},		"github": {
			"command": "uv",
			"args": [
				"run",
				"-i",
				"--rm",
				"-e",
				"GITHUB_PERSONAL_ACCESS_TOKEN",
				"mcp/github"
			],
			"env": {
				"GITHUB_PERSONAL_ACCESS_TOKEN": "${env:FORK_AUTOGEN_USER_PERSONAL_ACCESS_TOKEN}"
			}
		},
		"playwright": {
			"command": "npx",
			"args": [
				"-y",
				"@playwright/mcp"
			]
		}
	}
}