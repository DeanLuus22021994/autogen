# DevContainer Dockerfile for AutoGen with Docker Model Runner support
# Enhanced for permanent operation with precompiled code in volumes

FROM mcr.microsoft.com/devcontainers/base:ubuntu

# Arguments for customization
ARG PYTHON_VERSION=3.10
ARG DOTNET_VERSION=8.0
ARG USERNAME=vscode
ARG USER_UID=1000
ARG USER_GID=$USER_UID

# Environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PATH="${PATH}:/home/${USERNAME}/.local/bin" \
    DEBIAN_FRONTEND=noninteractive \
    MODEL_RUNNER_ENDPOINT="http://model-runner.docker.internal/engines/v1/chat/completions" \
    MODEL_RUNNER_MODELS_ENDPOINT="http://model-runner.docker.internal/engines" \
    DOTNET_SKIP_FIRST_TIME_EXPERIENCE=true

# Install system packages
RUN apt-get update && export DEBIAN_FRONTEND=noninteractive \
    && apt-get -y install --no-install-recommends \
        build-essential \
        curl \
        git \
        gnupg \
        lsb-release \
        software-properties-common \
        wget \
        jq \
        unzip \
        apt-transport-https \
        ca-certificates \
        netcat \
        libicu-dev \
        iputils-ping \
        dnsutils \
        tmux \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install Python
RUN add-apt-repository ppa:deadsnakes/ppa \
    && apt-get update \
    && apt-get install -y python${PYTHON_VERSION} python${PYTHON_VERSION}-dev python${PYTHON_VERSION}-venv python3-pip \
    && update-alternatives --install /usr/bin/python python /usr/bin/python${PYTHON_VERSION} 1 \
    && update-alternatives --install /usr/bin/python3 python3 /usr/bin/python${PYTHON_VERSION} 1 \
    && ln -sf /usr/bin/pip3 /usr/bin/pip \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install .NET SDK
RUN wget https://packages.microsoft.com/config/ubuntu/$(lsb_release -rs)/packages-microsoft-prod.deb -O packages-microsoft-prod.deb \
    && dpkg -i packages-microsoft-prod.deb \
    && rm packages-microsoft-prod.deb \
    && apt-get update \
    && apt-get install -y dotnet-sdk-${DOTNET_VERSION} \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install PowerShell for cross-platform shell support
RUN curl -sSL https://packages.microsoft.com/keys/microsoft.asc | apt-key add - \
    && echo "deb [arch=amd64] https://packages.microsoft.com/repos/microsoft-ubuntu-$(lsb_release -rs)-prod $(lsb_release -rs) main" > /etc/apt/sources.list.d/microsoft.list \
    && apt-get update \
    && apt-get install -y powershell \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Set up model cache directory with proper permissions
RUN mkdir -p /opt/autogen/models && chmod 777 /opt/autogen/models

# Set up symlinks for quick access to volumes
RUN ln -sf /workspaces/autogen/python/.venv /opt/python-env \
    && ln -sf /workspaces/autogen/dotnet/artifacts /opt/dotnet-artifacts

# Copy scripts and configuration files
COPY scripts/check-model-runner.sh /usr/local/bin/check-model-runner
COPY scripts/model-runner-check.sh /usr/local/bin/model-runner-check
COPY model-runner-config.xml /etc/autogen/model-runner-config.xml

# Make scripts executable
RUN chmod +x /usr/local/bin/check-model-runner \
    && chmod +x /usr/local/bin/model-runner-check

# Add Docker helper functions to ~/.bashrc for Bash shell
COPY scripts/bashrc-additions.sh /tmp/bashrc-additions.sh
RUN cat /tmp/bashrc-additions.sh >> /home/${USERNAME}/.bashrc \
    && rm /tmp/bashrc-additions.sh

# Add Docker helper functions to PowerShell profile
COPY scripts/powershell-profile.ps1 /tmp/powershell-profile.ps1
RUN mkdir -p /home/${USERNAME}/.config/powershell \
    && cat /tmp/powershell-profile.ps1 > /home/${USERNAME}/.config/powershell/Microsoft.PowerShell_profile.ps1 \
    && rm /tmp/powershell-profile.ps1

# Set ownership for the user
RUN chown -R ${USERNAME}:${USER_GID} /home/${USERNAME}

# Clean up
RUN apt-get autoremove -y \
    && apt-get clean -y \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspaces/autogen

# Create healthcheck
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -s --fail "http://model-runner.docker.internal/engines" > /dev/null || exit 1